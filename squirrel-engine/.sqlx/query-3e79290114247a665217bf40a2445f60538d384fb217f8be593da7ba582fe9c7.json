  "query": "\n        SELECT u.telegram_id as id, u.username, u.rating, u.photo_url, u.xp, uei.equipped_deck_id as equipped_deck\n        FROM users u\n        LEFT JOIN user_equipped_items uei ON u.telegram_id = uei.telegram_id\n        WHERE u.telegram_id = $1\n        ",
