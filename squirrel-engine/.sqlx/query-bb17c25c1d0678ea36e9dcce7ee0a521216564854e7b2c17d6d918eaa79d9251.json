{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT cm.id, cm.sender_id, cm.message, cm.created_at, u.username\n        FROM clan_messages cm\n        JOIN users u ON u.telegram_id = cm.sender_id\n        WHERE cm.clan_id = $1\n        ORDER BY cm.created_at DESC\n        LIMIT 50\n        ",
