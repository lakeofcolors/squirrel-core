  "query": "\n                        SELECT u.telegram_id, u.username, u.rating, u.photo_url, u.xp\n                        FROM ghost_bots gb\n                        JOIN users u ON gb.telegram_id = u.telegram_id\n                        WHERE gb.is_active = true\n                        ORDER BY RANDOM()\n                        LIMIT 20\n                        ",
